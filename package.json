{
  "name": "vitra-css",
  "version": "1.4.0",
  "description": "A lightweight CSS framework focused on glassmorphism, configurable particles with glow effects, and smooth motion",
  "main": "dist/vitra.js",
  "module": "dist/vitra.esm.js",
  "style": "dist/vitra.css",
  "types": "dist/vitra.d.ts",
  "exports": {
    ".": {
      "style": "./dist/vitra.css",
      "import": "./dist/vitra.esm.js",
      "require": "./dist/vitra.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:css": "node scripts/build-css.js",
    "build:js": "esbuild src/vitra.js --bundle --outfile=dist/vitra.js --format=iife --global-name=Vitra --sourcemap && esbuild src/vitra.js --bundle --minify --outfile=dist/vitra.min.js --format=iife --global-name=Vitra --sourcemap",
    "build:esm": "esbuild src/vitra.js --bundle --outfile=dist/vitra.esm.js --format=esm --sourcemap",
    "build": "npm run build:css && npm run build:js && npm run build:esm",
    "postbuild": "node generate-sri.js > dist/SRI.txt",
    "prepublishOnly": "npm test && npm run build",
    "dev": "npx serve .",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "stylelint \"src/**/*.css\" --fix",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/vitra.min.css",
      "limit": "85 kB"
    },
    {
      "path": "dist/vitra.min.js",
      "limit": "15 kB"
    },
    {
      "path": "dist/vitra.esm.js",
      "limit": "30 kB"
    }
  ],
  "devDependencies": {
    "@size-limit/file": "^12.1.0",
    "esbuild": "^0.24.2",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "size-limit": "^12.1.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "css",
    "framework",
    "glassmorphism",
    "particles",
    "motion",
    "design-system",
    "ui-components"
  ],
  "author": "DesvoSoft",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/desvosoft/vitra-css.git"
  },
  "bugs": {
    "url": "https://github.com/desvosoft/vitra-css/issues"
  },
  "homepage": "https://vitra-css.dev"
}
